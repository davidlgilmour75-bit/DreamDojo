# Copy this file to .dreamdojo-cloud.env at repo root or source directly.
# Example:
#   cp cloud/lambda/dreamdojo.lambda.env.example .dreamdojo-cloud.env
#   source .dreamdojo-cloud.env

export REPO_ROOT="$HOME/DreamDojo"

# Prefer Lambda persistent filesystem if attached. Fall back to local disk.
export DREAMDOJO_STORAGE_ROOT="/lambda/nfs/dreamdojo"

export HF_HOME="$DREAMDOJO_STORAGE_ROOT/hf_cache"
export IMAGINAIRE_OUTPUT_ROOT="$DREAMDOJO_STORAGE_ROOT/outputs/training"
export CHECKPOINTS_DIR="$DREAMDOJO_STORAGE_ROOT/checkpoints"
export SAVE_DIR="$DREAMDOJO_STORAGE_ROOT/outputs/eval"

# Dataset layout
export DATASET_ROOT="$DREAMDOJO_STORAGE_ROOT/datasets/PhysicalAI-Robotics-GR00T-Teleop-GR1"
export TRAIN_DATASET_PATH="$DATASET_ROOT/GR1_robot"
export EVAL_DATASET_PATH="$DATASET_ROOT/GR1_robot"

# Distributed launch defaults
export NNODES=1
export NPROC=8
export MASTER_ADDR=127.0.0.1
export MASTER_PORT=12341
export NODE_RANK=0

# W&B
export WANDB_MODE=online
# export WANDB_API_KEY=your_wandb_key_here
